extends layout

block content
  section.hero
    h2 Downtown Donuts
    p.tagline Family-Owned Since 1992

    p.description Fresh, handcrafted donuts and locally roasted coffee made daily in the heart of downtown.

		.hero-buttons
			a.btn(href="/menu") View Menu
			a.btn(href="/comments") Leave a Comment

		section.order-preview
			h2 Order Online
			p Get Downtown Donuts delivered through one of our ordering partners.

			.order-buttons
				a.btn(href="https://www.ubereats.com", target="_blank", rel="noopener noreferrer") UberEats
				a.btn(href="https://www.doordash.com", target="_blank", rel="noopener noreferrer") DoorDash
				a.btn(href="https://www.grubhub.com", target="_blank", rel="noopener noreferrer") GrubHub
